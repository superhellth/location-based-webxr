{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "esnext.disposable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "gps-plus-slam-js": ["../GpsPlusSlamJs/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../GpsPlusSlamJs/src/**/*.ts"],
  "exclude": [
    "dist",
    "coverage",
    "node_modules",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.property.test.ts",
    "src/test-utils/**",
    "src/test-setup.ts",
    "../GpsPlusSlamJs/src/**/*.test.ts",
    "../GpsPlusSlamJs/src/**/*.spec.ts",
    "../GpsPlusSlamJs/src/perf/**"
  ]
}
