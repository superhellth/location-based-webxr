{
    "name": "location-based-webxr",
    "version": "0.1.0",
    "private": true,
    "description": "Open-source AR+GPS framework and recorder app for location-based WebXR experiences.",
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "build:framework": "pnpm run --filter gps-plus-slam-app-framework... build",
        "build:recorder": "pnpm run --filter gps-plus-slam-recorder... build",
        "build:example": "pnpm run --filter gps-plus-slam-minimal-example... build",
        "check:deadcode": "knip",
        "test:framework": "pnpm --filter gps-plus-slam-app-framework test",
        "test:recorder": "pnpm --filter gps-plus-slam-recorder test",
        "test:recorder:unit": "pnpm --filter gps-plus-slam-recorder run test:unit",
        "test:recorder:e2e": "pnpm --filter gps-plus-slam-recorder run test:e2e",
        "test:example": "pnpm --filter gps-plus-slam-minimal-example test",
        "test": "pnpm run test:framework && pnpm run test:recorder && pnpm run test:example"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "license": "Apache-2.0",
    "devDependencies": {
        "knip": "^6.7.0"
    }
}