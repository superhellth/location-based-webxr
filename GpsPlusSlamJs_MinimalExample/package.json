{
  "name": "gps-plus-slam-minimal-example",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal getting-started example consuming gps-plus-slam-app-framework + gps-plus-slam-js: Three.js scene driven by createRecorderStore().",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "pnpm run typecheck && pnpm run test:unit",
    "test:unit": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "gps-plus-slam-app-framework": "workspace:*",
    "gps-plus-slam-js": "^1.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "license": "Apache-2.0"
}
