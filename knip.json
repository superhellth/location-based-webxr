{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "rules": {
    "exports": "error",
    "types": "error"
  },
  "workspaces": {
    ".": {
      "entry": ["tests/**/*.test.js"],
      "project": ["tests/**/*.js"]
    },
    "GpsPlusSlamJs_AppFramework": {
      "entry": [
        "src/index.ts",
        "src/ar/index.ts",
        "src/core/index.ts",
        "src/sensors/index.ts",
        "src/state/index.ts",
        "src/storage/index.ts",
        "src/visualization/index.ts",
        "src/utils/index.ts",
        "src/types/index.ts",
        "src/types/global.d.ts",
        "src/types/webxr.d.ts",
        "src/licensing/index.ts",
        "src/test-utils/**/*.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "GpsPlusSlamJs_RecorderApp": {
      "entry": [
        "src/global.d.ts",
        "config/stylelint.config.mjs",
        "playwright-tests/**/*.{js,ts}"
      ],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@carlosjeurissen/stylelint-csstree-validator",
        "postcss-html",
        "stylelint-config-standard",
        "webxr-polyfill"
      ]
    },
    "GpsPlusSlamJs_AnchorStarter": {
      "entry": [
        "config/stylelint.config.mjs",
        "playwright-tests/**/*.{js,ts}"
      ],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@carlosjeurissen/stylelint-csstree-validator",
        "postcss-html",
        "stylelint-config-standard"
      ]
    },
    "GpsPlusSlamJs_MinimalExample": {
      "project": ["src/**/*.ts"]
    },
    "GpsPlusSlamJs_QrTrackingDemo": {
      "entry": [
        "config/stylelint.config.mjs",
        "playwright-tests/**/*.{js,ts}"
      ],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@carlosjeurissen/stylelint-csstree-validator",
        "postcss-html",
        "stylelint-config-standard"
      ]
    },
    "GpsPlusSlamJs_BillboardDemo": {
      "entry": ["config/stylelint.config.mjs"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "@carlosjeurissen/stylelint-csstree-validator",
        "postcss-html",
        "stylelint-config-standard"
      ]
    }
  }
}