{
  "name": "gps-plus-slam-recorder",
  "version": "0.1.0",
  "description": "WebXR/Three.js recorder app for capturing AR sessions with GPS data for the GpsPlusSlamJs library.",
  "type": "module",
  "files": [
    "index.html",
    "styles/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "tsc && vite build --config config/vite.config.ts",
    "preview": "vite preview --config config/vite.config.ts",
    "test": "pnpm run test:core && pnpm run test:e2e",
    "test:core": "pnpm run format && pnpm run lint && pnpm run lint:css && pnpm run check:all && pnpm run typecheck && pnpm run typecheck:tests && pnpm run test:unit",
    "test:unit": "vitest run --coverage --config config/vitest.config.ts",
    "test:investigation": "pnpm --filter gps-plus-slam-investigation test",
    "test:watch": "vitest --config config/vitest.config.ts",
    "test:e2e": "pnpm exec playwright --version && playwright test --config playwright-tests/playwright.config.js",
    "test:e2e:headed": "playwright test --config playwright-tests/playwright.config.js --headed",
    "test:e2e:ui": "playwright test --config playwright-tests/playwright.config.js --ui",
    "format": "prettier --log-level warn --write --ignore-unknown --no-error-on-unmatched-pattern \"src\" \"config\" \"playwright-tests\" index.html README.md package.json",
    "format:check": "prettier --check --ignore-unknown .",
    "lint": "eslint . --config config/eslint.config.mjs",
    "lint:css": "stylelint \"src/**/*.css\" \"**/*.html\" --config config/stylelint.config.mjs --allow-empty-input",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.vitest.json --noEmit",
    "check:dup": "jscpd --config config/.jscpd.json src",
    "check:cycles": "dpdm -T --exit-code circular:1 --no-warning --no-tree ./src/main.ts",
    "check:boundaries": "depcruise -c config/.dependency-cruiser.cjs src",
    "check:deadcode": "knip --config config/knip.json",
    "check:all": "pnpm run check:dup && pnpm run check:cycles && pnpm run check:boundaries && pnpm run check:deadcode",
    "setup": "bash ./scripts/setup.sh"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/browser": "^10.49.0",
    "@types/leaflet": "^1.9.21",
    "@zip.js/zip.js": "^2.8.26",
    "gl-matrix": "3.4.4",
    "gps-plus-slam-app-framework": "workspace:*",
    "gps-plus-slam-js": "^1.0.0",
    "h3-js": "^4.4.0",
    "leaflet": "^1.9.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@carlosjeurissen/stylelint-csstree-validator": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sentry/vite-plugin": "^5.2.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "dependency-cruiser": "^17.3.10",
    "dpdm": "^4.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "jscpd": "^4.0.9",
    "jsdom": "^29.0.2",
    "knip": "^6.6.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "webxr-polyfill": "^2.0.3"
  },
  "keywords": [
    "webxr",
    "threejs",
    "ar",
    "gps",
    "recorder"
  ],
  "author": "cs-util-com",
  "license": "Apache-2.0"
}
